# ─── PostgreSQL (Aiven Cloud) ─────────────────────────────────────────
# Get the DATABASE_URL from your team lead or the project's secure channel
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require

# ─── JWT ──────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=28800

# ─── App URL ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Setu Sandbox Credentials (DigiLocker API) ─────────────────────────
SETU_CLIENT_ID=your-setu-client-id
SETU_CLIENT_SECRET=your-setu-client-secret
SETU_PRODUCT_INSTANCE_ID=your-setu-product-instance-id
SETU_BASE_URL=https://dg-sandbox.setu.co

# ─── AWS Bedrock (AI Copilot) ──────────────────────────────────────────
# Get AWS credentials from your team lead or the project's secure channel
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-south-1
BEDROCK_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0
