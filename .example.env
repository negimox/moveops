# ─── PostgreSQL (AWS RDS) ─────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=postgres://****

# ─── JWT ──────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=Generate a strong secret: openssl rand -base64 32

# JWT cookie lifetime in seconds (8 hours)
JWT_EXPIRES_IN=28800

# ─── App URL (used for Setu DigiLocker redirect callback) ─────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Setu DigiLocker Sandbox API ──────────────────────────────────────────
# Register at https://bridge.setu.co to obtain these credentials.
SETU_BASE_URL=
SETU_CLIENT_ID=
SETU_CLIENT_SECRET=
SETU_PRODUCT_INSTANCE_ID=

# ─── Safety Officer Alerts ─────────────────────────────────────────────────
# Recipient for DigiLocker DL verification alert emails (EXPIRED / INVALID).
# Falls back to TEST_EMAIL if not set.
SAFETY_OFFICER_EMAIL=

AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=